---
import Elementor from "./icons/Elementor.astro";
import Wordpress from "./icons/Wordpress.astro";

const TAGS = {
  WORDPRESS: {
    name: "Wordpress",
    class: "bg-blue-500/20 text-blue-500",
    icon: Wordpress,
  },
  ELEMENTOR: {
    name: "Elementor",
    class: "bg-orange-500/20 text-orange-500",
    icon: Elementor,
  },
};

const PROJECTS = [
  {
    title: "CIBCON - Seguridad y Tecnología",
    description:
      "Diseño y desarrollo de página web para CIBCON, empresa dedicada a la seguridad y tecnología.",
    link: "https://cibcon.com/",
    github: "No GitHub",
    image: "/src/assets/projects/cibcon-screen.jpg",
    tags: [TAGS.WORDPRESS, TAGS.ELEMENTOR],
  },

  {
    title: "MedMatch - Plataforma de Citas Médicas",
    description:
      "Diseño y desarrollo de aplicación móvil para KININ, plataforma de salud a domicilio",
    link: "",
    github: "GitHub Privado",
    image: "/src/assets/projects/medmatch-screen.jpg",
    tags: [],
    video: "https://youtu.be/ipx92FVoHSo",
  },
];
---

<div class="flex flex-row flex-wrap gap-4">
  {
    PROJECTS.map(({ image, title, description, tags, link, video }) => (
      <div class="bg-neutral-primary-soft block max-w-sm p-6 border border-default rounded-base shadow-xs">
        <a href={link || video}>
          <img
            class="rounded-base w-full aspect-video object-cover"
            src={image}
            alt={title}
          />
        </a>
        <h5 class="mt-6 mb-2 text-2xl font-semibold tracking-tight text-heading">
          {title}
        </h5>
        <p class="mb-6 text-body">{description}</p>

        {video ? (
          <button
            data-video={video}
            class="video-btn inline-flex items-center text-body bg-neutral-secondary-medium box-border border border-default-medium hover:bg-neutral-tertiary-medium hover:text-heading focus:ring-4 focus:ring-neutral-tertiary shadow-xs font-medium leading-5 rounded-base text-sm px-4 py-2.5 focus:outline-none cursor-pointer"
          >
            Ver Video
            <svg class="w-4 h-4 ms-1.5" fill="currentColor" viewBox="0 0 20 20">
              <path d="M10 18a8 8 0 100-16 8 8 0 000 16zM9.555 7.168A1 1 0 008 8v4a1 1 0 001.555.832l3-2a1 1 0 000-1.664l-3-2z" />
            </svg>
          </button>
        ) : (
          <a
            href={link}
            target="_blank"
            class="inline-flex items-center text-body bg-neutral-secondary-medium box-border border border-default-medium hover:bg-neutral-tertiary-medium hover:text-heading focus:ring-4 focus:ring-neutral-tertiary shadow-xs font-medium leading-5 rounded-base text-sm px-4 py-2.5 focus:outline-none"
          >
            Visitar
            <svg
              class="w-4 h-4 ms-1.5 rtl:rotate-180 -me-0.5"
              aria-hidden="true"
              xmlns="http://www.w3.org/2000/svg"
              width="24"
              height="24"
              fill="none"
              viewBox="0 0 24 24"
            >
              <path
                stroke="currentColor"
                stroke-linecap="round"
                stroke-linejoin="round"
                stroke-width="2"
                d="M19 12H5m14 0-4 4m4-4-4-4"
              />
            </svg>
          </a>
        )}
      </div>
    ))
  }
</div>

<!-- Modal de Video -->
<dialog
  id="video-modal"
  class="backdrop:bg-black/90 rounded-2xl p-0 overflow-hidden border-none shadow-2xl w-[90%] max-w-4xl bg-transparent fixed inset-0 m-auto"
>
  <div class="relative pt-[56.25%] bg-black group">
    <iframe
      id="modal-iframe"
      class="absolute top-0 left-0 w-full h-full"
      allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture"
      allowfullscreen></iframe>

    <button
      id="close-modal"
      class="absolute top-4 right-4 bg-white/20 hover:bg-white/40 text-white w-10 h-10 rounded-full flex items-center justify-center backdrop-blur-md transition-all z-50 cursor-pointer"
      title="Cerrar"
    >
      <svg
        xmlns="http://www.w3.org/2000/svg"
        class="w-6 h-6"
        fill="none"
        viewBox="0 0 24 24"
        stroke="currentColor"
      >
        <path
          stroke-linecap="round"
          stroke-linejoin="round"
          stroke-width="2"
          d="M6 18L18 6M6 6l12 12"></path>
      </svg>
    </button>
  </div>
</dialog>

<script>
  const modal = document.getElementById("video-modal") as HTMLDialogElement;
  const iframe = document.getElementById("modal-iframe") as HTMLIFrameElement;
  const closeBtn = document.getElementById("close-modal");
  const videoBtns = document.querySelectorAll(".video-btn");

  // Función para convertir URLs de YouTube a formato embed
  const getEmbedUrl = (url: string) => {
    if (url.includes("youtube.com/embed/")) return url;

    let videoId = "";
    if (url.includes("youtu.be/")) {
      videoId = url.split("youtu.be/")[1].split(/[?#]/)[0];
    } else if (url.includes("youtube.com/watch")) {
      videoId = new URLSearchParams(new URL(url).search).get("v") || "";
    }

    return videoId
      ? `https://www.youtube.com/embed/${videoId}?autoplay=1`
      : url;
  };

  videoBtns.forEach((btn) => {
    btn.addEventListener("click", (e) => {
      e.preventDefault();
      const videoUrl = btn.getAttribute("data-video");
      if (videoUrl && modal && iframe) {
        iframe.src = getEmbedUrl(videoUrl);
        modal.showModal();
        // Asegurar que el scroll del body se bloquee
        document.body.style.overflow = "hidden";
      }
    });
  });

  const closeModal = () => {
    if (modal && iframe) {
      modal.close();
      iframe.src = "";
      document.body.style.overflow = "auto";
    }
  };

  closeBtn?.addEventListener("click", closeModal);

  modal?.addEventListener("click", (e) => {
    if (e.target === modal) {
      closeModal();
    }
  });

  // Cerrar con tecla Escape (por si el navegador no lo hace por defecto)
  document.addEventListener("keydown", (e) => {
    if (e.key === "Escape" && modal.open) {
      closeModal();
    }
  });
</script>

<style>
  dialog::backdrop {
    background: rgba(0, 0, 0, 0.85);
    backdrop-filter: blur(4px);
    animation: fadeIn 0.3s ease-out;
  }

  dialog[open] {
    animation: zoomIn 0.3s cubic-bezier(0.34, 1.56, 0.64, 1);
  }

  @keyframes fadeIn {
    from {
      opacity: 0;
    }
    to {
      opacity: 1;
    }
  }

  @keyframes zoomIn {
    from {
      transform: scale(0.95);
      opacity: 0;
    }
    to {
      transform: scale(1);
      opacity: 1;
    }
  }
</style>
